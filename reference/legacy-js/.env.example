PORT=3000
KEYCRM_API_BASE=https://openapi.keycrm.app/v1
KEYCRM_TOKEN=PASTE_YOUR_KEYCRM_TOKEN_HERE
KEYCRM_REQUEST_TIMEOUT_MS=15000
KEYCRM_REQUEST_RETRIES=2
KEYCRM_REQUEST_RETRY_BASE_MS=500
TEST_ORDER_ID=28658
OUTPUT_DIR=./outputs
FONT_PATH=./Caveat-VariableFont_wght.ttf
# Optional fallback font for emoji glyphs in text-mode rendering.
# Use an outline emoji font (e.g. Symbola, NotoEmoji-Regular).
# Example: ./fonts/Symbola.ttf
EMOJI_FONT_PATH=
# Emoji render mode:
# - apple_image: renders emoji as Apple-style PNG (from assets dir or base URL)
# - font: renders emoji via glyph fallback font (EMOJI_FONT_PATH)
EMOJI_RENDER_MODE=apple_image
# Optional base URL for Apple emoji PNG files (codepoint-keyed, e.g. 1f618.png, 2764-fe0f.png)
# Leave empty to use local assets only.
APPLE_EMOJI_BASE_URL=
# Local directory with Apple emoji PNG files. If empty, bot auto-uses:
# ./node_modules/emoji-datasource-apple/img/apple/64
APPLE_EMOJI_ASSETS_DIR=
STICKER_SIZE_MM=100
PDF_COLOR_SPACE=RGB
# White replacement (#FFFFFF -> #FFFEFA) is always enabled
OFFWHITE_HEX=FFFEFA
# White replacement mode:
# - photoshop_like: Lab + softness + feather (recommended for максимально близько до Photoshop)
# - threshold: простий пороговий режим
WHITE_REPLACE_MODE=photoshop_like
# Near-white selection base tuning.
# Photoshop Color Range equivalent from your screenshot:
# - Fuzziness: 3
# - Color model: Lab, white point
WHITE_THRESHOLD=252
WHITE_MAX_SATURATION=0.03
# Photoshop-like tuning (used when WHITE_REPLACE_MODE=photoshop_like)
WHITE_LAB_DELTA_E_MAX=3
WHITE_LAB_SOFTNESS=1
WHITE_MIN_LIGHTNESS=99.5
WHITE_FEATHER_PX=0.35
WHITE_MIN_ALPHA=0
# Optional cleanup passes for residual pure-white pixels (3 = max cleanup priority)
WHITE_CLEANUP_PASSES=3
WHITE_CLEANUP_MIN_CHANNEL=248
WHITE_CLEANUP_MAX_SATURATION=0.35
# Extra aggressive hard cleanup for tiny near-white leftovers (post-mask safety net)
WHITE_HARD_CLEANUP_PASSES=2
WHITE_HARD_MIN_CHANNEL=246
WHITE_HARD_MIN_LIGHTNESS=98.5
WHITE_HARD_DELTA_E_MAX=14
WHITE_HARD_MAX_SATURATION=0.6
# Normalize hidden RGB on fully transparent pixels to avoid white speck artifacts in some viewers
WHITE_ZERO_TRANSPARENT_RGB=true
# Full recolor iterations (3 = max cleanup priority)
WHITE_REPLACE_ITERATIONS=3
# Keep true to preserve transparent regions and avoid black background fills
WHITE_ALLOW_SOFT_MASK_FALLBACK=true
# Final strict pass after CMYK: replaces exact pure white (255,255,255) without touching other tones
WHITE_FINAL_ENFORCE=true
WHITE_FINAL_ITERATIONS=3
# Final near-white threshold for tiny residual speckles
WHITE_FINAL_THRESHOLD=254
WHITE_FINAL_MAX_SATURATION=0.25
# Lower DPI for final pass keeps output size reasonable
WHITE_FINAL_DPI=300
RASTERIZE_DPI=600
TELEGRAM_BOT_TOKEN=PASTE_YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=
TELEGRAM_REQUEST_TIMEOUT_MS=30000
TELEGRAM_REQUEST_RETRIES=2
TELEGRAM_RETRY_BASE_MS=900
TELEGRAM_MESSAGE_MAP_PATH=./outputs/telegram-message-map.json
TELEGRAM_MESSAGE_MAP_MAX_ENTRIES=25000
TELEGRAM_REACTION_ENABLED=true
TELEGRAM_REACTION_SECRET_TOKEN=
TELEGRAM_REACTION_TARGET_STATUS_ID=
TELEGRAM_REACTION_HEART_THRESHOLD=2
TELEGRAM_REACTION_HEART_EMOJIS=❤️,❤
# For Telegram webhook setWebhook use both update types:
# allowed_updates=["message_reaction_count","message_reaction"]
# QR placement on poster PDF: bottom-right corner by default
# 10 mm from right side, 10 mm from bottom, size 20x20 mm
QR_RIGHT_MM=10
QR_BOTTOM_MM=10
QR_SIZE_MM=20
# Optional per-format overrides:
# QR_A5_RIGHT_MM=10
# QR_A5_BOTTOM_MM=10
# QR_A5_SIZE_MM=20
# QR_A4_RIGHT_MM=10
# QR_A4_BOTTOM_MM=10
# QR_A4_SIZE_MM=20
URL_SHORTENER_PROVIDER=cuttly
URL_SHORTENER_TIMEOUT_MS=7000
URL_SHORTENER_RETRIES=2
URL_SHORTENER_RETRY_BASE_MS=500
URL_SHORTENER_REQUIRED=true
CUTTLY_API_KEY=PASTE_CUTTLY_API_KEY_HERE
KEYCRM_ORDER_INCLUDE=products.offer,tags,custom_fields,status,manager,shipping.deliveryService,shipping.lastHistory

# In-process order queue (protects from overload and duplicates)
ORDER_QUEUE_CONCURRENCY=2
ORDER_QUEUE_MAX_SIZE=100
ORDER_JOB_TIMEOUT_MS=900000
ORDER_QUEUE_DEDUPE=true

# Webhook processing mode
# false: only fetch order summary (safe default)
# true: full order processing with generation/telegram options below
WEBHOOK_PROCESS_ORDERS=false
WEBHOOK_GENERATE_FILES=false
WEBHOOK_SEND_TELEGRAM=false
# true = webhook waits until processing is done; false = returns quickly and processes in background
WEBHOOK_WAIT_FOR_COMPLETION=false
