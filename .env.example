APP_ROLE=all
HOST=127.0.0.1
PORT=3000
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/custom_gifts_bot
DATABASE_POOL_MAX=10
DATABASE_AUTO_MIGRATE_ON_BOOT=true
DATABASE_MIGRATIONS_DIR=migrations

# Core integrations
KEYCRM_API_BASE=https://openapi.keycrm.app/v1
KEYCRM_TOKEN=PASTE_YOUR_KEYCRM_TOKEN_HERE
TELEGRAM_BOT_TOKEN=PASTE_YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=
TELEGRAM_ORDERS_CHAT_ID=
TELEGRAM_ORDERS_THREAD_ID=
TELEGRAM_FORWARD_MODE=copy
TELEGRAM_OPS_CHAT_ID=
TELEGRAM_OPS_THREAD_ID=

# Webhook security (optional but recommended)
KEYCRM_WEBHOOK_SECRET=
TELEGRAM_REACTION_SECRET_TOKEN=

# Telegram request policy
TELEGRAM_REQUEST_TIMEOUT_MS=30000
TELEGRAM_REQUEST_RETRIES=2
TELEGRAM_REQUEST_RETRY_BASE_MS=900
OPS_ALERT_TIMEOUT_MS=15000
OPS_ALERT_RETRIES=2
OPS_ALERT_RETRY_BASE_MS=700
OPS_ALERT_DEDUPE_WINDOW_MS=60000

# Request limits
REQUEST_BODY_LIMIT_BYTES=1000000

# KeyCRM request policy
KEYCRM_ORDER_INCLUDE=products.offer,tags,custom_fields,status,manager,shipping.deliveryService,shipping.lastHistory
KEYCRM_REQUEST_TIMEOUT_MS=15000
KEYCRM_REQUEST_RETRIES=2
KEYCRM_REQUEST_RETRY_BASE_MS=500
SPOTIFY_REQUEST_TIMEOUT_MS=12000
SPOTIFY_REQUEST_RETRIES=2
SPOTIFY_REQUEST_RETRY_BASE_MS=700
SHORTENER_REQUEST_TIMEOUT_MS=7000
SHORTENER_REQUEST_RETRIES=2
SHORTENER_REQUEST_RETRY_BASE_MS=500
LNK_UA_BEARER_TOKEN=public
CUTTLY_API_KEY=
PDF_SOURCE_REQUEST_TIMEOUT_MS=20000
PDF_SOURCE_REQUEST_RETRIES=2
PDF_SOURCE_REQUEST_RETRY_BASE_MS=800

# Intake queue policy
ORDER_QUEUE_CONCURRENCY=1
ORDER_QUEUE_MAX_SIZE=200
ORDER_QUEUE_MAX_ATTEMPTS=3
ORDER_QUEUE_RETRY_BASE_MS=1000
REACTION_QUEUE_CONCURRENCY=1
REACTION_QUEUE_MAX_SIZE=300
REACTION_QUEUE_MAX_ATTEMPTS=2
REACTION_QUEUE_RETRY_BASE_MS=500
QUEUE_JOB_TIMEOUT_MS=600000
QUEUE_POLL_INTERVAL_MS=1000

# Database retention policy
IDEMPOTENCY_MAX_ENTRIES=50000
TEMP_DIR=storage/temp
OUTPUT_RETENTION_HOURS=168
TEMP_RETENTION_HOURS=24
CLEANUP_INTERVAL_MS=3600000
DB_CLEANUP_INTERVAL_MS=3600000
QUEUE_JOB_RETENTION_HOURS=72
TELEGRAM_DELIVERY_RETENTION_HOURS=720
FORWARDING_BATCH_RETENTION_HOURS=720
DEAD_LETTER_RETENTION_HOURS=336

# Business rules
PRODUCT_CODE_RULES_PATH=config/business-rules/product-code-rules.json
REACTION_STATUS_RULES_PATH=config/business-rules/reaction-status-rules.json
QR_RULES_PATH=config/business-rules/qr-rules.json
TELEGRAM_MESSAGE_MAP_MAX_ENTRIES=50000

# PDF pipeline
OUTPUT_DIR=storage/files/materials
FONT_PATH=assets/fonts/Caveat-VariableFont_wght.ttf
EMOJI_FONT_PATH=
EMOJI_RENDER_MODE=apple_image
APPLE_EMOJI_BASE_URL=
APPLE_EMOJI_ASSETS_DIR=
PDF_COLOR_SPACE=CMYK
STICKER_SIZE_MM=100
OFFWHITE_HEX=FFFEFA
RASTERIZE_DPI=600

# Generic QR fallback placement by format
QR_A5_RIGHT_MM=10
QR_A5_BOTTOM_MM=10
QR_A5_SIZE_MM=20
QR_A4_RIGHT_MM=10
QR_A4_BOTTOM_MM=10
QR_A4_SIZE_MM=30

# Health / readiness
READINESS_PROBE_TIMEOUT_MS=5000
READINESS_MIN_DISK_FREE_BYTES=536870912
