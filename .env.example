HOST=127.0.0.1
PORT=3000

# Core integrations
KEYCRM_API_BASE=https://openapi.keycrm.app/v1
KEYCRM_TOKEN=PASTE_YOUR_KEYCRM_TOKEN_HERE
TELEGRAM_BOT_TOKEN=PASTE_YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=

# Webhook security (optional but recommended)
KEYCRM_WEBHOOK_SECRET=
TELEGRAM_REACTION_SECRET_TOKEN=

# Telegram request policy
TELEGRAM_REQUEST_TIMEOUT_MS=30000
TELEGRAM_REQUEST_RETRIES=2
TELEGRAM_REQUEST_RETRY_BASE_MS=900

# Request limits
REQUEST_BODY_LIMIT_BYTES=1000000

# KeyCRM request policy
KEYCRM_ORDER_INCLUDE=products.offer,tags,custom_fields,status,manager,shipping.deliveryService,shipping.lastHistory
KEYCRM_REQUEST_TIMEOUT_MS=15000
KEYCRM_REQUEST_RETRIES=2
KEYCRM_REQUEST_RETRY_BASE_MS=500

# Intake queue policy
ORDER_QUEUE_CONCURRENCY=1
ORDER_QUEUE_MAX_SIZE=200
REACTION_QUEUE_CONCURRENCY=1
REACTION_QUEUE_MAX_SIZE=300
QUEUE_JOB_TIMEOUT_MS=600000

# Persistent storage
IDEMPOTENCY_STORE_PATH=storage/files/idempotency/order-webhooks.json

# Business rules
PRODUCT_CODE_RULES_PATH=config/business-rules/product-code-rules.json
REACTION_STATUS_RULES_PATH=config/business-rules/reaction-status-rules.json
QR_RULES_PATH=config/business-rules/qr-rules.json
TELEGRAM_MESSAGE_MAP_PATH=storage/files/telegram/message-map.json
TELEGRAM_LEGACY_CLIENT_PATH=reference/legacy-js/telegram-client.js

# PDF pipeline
OUTPUT_DIR=storage/files/materials
FONT_PATH=reference/legacy-js/Caveat-VariableFont_wght.ttf
EMOJI_FONT_PATH=
EMOJI_RENDER_MODE=apple_image
APPLE_EMOJI_BASE_URL=
APPLE_EMOJI_ASSETS_DIR=
PDF_LEGACY_MODULE_PATH=reference/legacy-js/material-generator.js
PDF_COLOR_SPACE=CMYK
STICKER_SIZE_MM=100
OFFWHITE_HEX=FFFEFA
RASTERIZE_DPI=600

# Generic QR fallback placement by format
QR_A5_RIGHT_MM=10
QR_A5_BOTTOM_MM=10
QR_A5_SIZE_MM=20
QR_A4_RIGHT_MM=10
QR_A4_BOTTOM_MM=10
QR_A4_SIZE_MM=30
