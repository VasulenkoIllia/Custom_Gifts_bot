HOST=0.0.0.0
PORT=3000
DATABASE_URL=postgres://user:password@postgres:5432/custom_gifts_bot
DATABASE_POOL_MAX=20

# Core integrations
KEYCRM_API_BASE=https://openapi.keycrm.app/v1
KEYCRM_TOKEN=PASTE_PROD_KEYCRM_TOKEN
TELEGRAM_BOT_TOKEN=PASTE_PROD_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=-1000000000000
TELEGRAM_MESSAGE_THREAD_ID=
TELEGRAM_OPS_CHAT_ID=-1000000000000
TELEGRAM_OPS_THREAD_ID=

# Webhook security
KEYCRM_WEBHOOK_SECRET=SET_STRONG_SECRET
TELEGRAM_REACTION_SECRET_TOKEN=SET_STRONG_SECRET

# Request policy
REQUEST_BODY_LIMIT_BYTES=1000000
KEYCRM_ORDER_INCLUDE=products.offer,tags,custom_fields,status,manager,shipping.deliveryService,shipping.lastHistory
KEYCRM_REQUEST_TIMEOUT_MS=15000
KEYCRM_REQUEST_RETRIES=2
KEYCRM_REQUEST_RETRY_BASE_MS=500
TELEGRAM_REQUEST_TIMEOUT_MS=30000
TELEGRAM_REQUEST_RETRIES=2
TELEGRAM_REQUEST_RETRY_BASE_MS=900

# Ops alerting
OPS_ALERT_TIMEOUT_MS=15000
OPS_ALERT_RETRIES=2
OPS_ALERT_RETRY_BASE_MS=700
OPS_ALERT_DEDUPE_WINDOW_MS=60000

# Queue policy
ORDER_QUEUE_CONCURRENCY=1
ORDER_QUEUE_MAX_SIZE=200
ORDER_QUEUE_MAX_ATTEMPTS=3
ORDER_QUEUE_RETRY_BASE_MS=1000
REACTION_QUEUE_CONCURRENCY=1
REACTION_QUEUE_MAX_SIZE=300
REACTION_QUEUE_MAX_ATTEMPTS=2
REACTION_QUEUE_RETRY_BASE_MS=500
QUEUE_JOB_TIMEOUT_MS=600000

# Storage retention
IDEMPOTENCY_MAX_ENTRIES=50000
TELEGRAM_MESSAGE_MAP_MAX_ENTRIES=50000
OUTPUT_DIR=storage/files/materials
TEMP_DIR=storage/temp
OUTPUT_RETENTION_HOURS=168
TEMP_RETENTION_HOURS=24
CLEANUP_INTERVAL_MS=3600000

# Rules and legacy adapters
PRODUCT_CODE_RULES_PATH=config/business-rules/product-code-rules.json
QR_RULES_PATH=config/business-rules/qr-rules.json
REACTION_STATUS_RULES_PATH=config/business-rules/reaction-status-rules.json
TELEGRAM_LEGACY_CLIENT_PATH=reference/legacy-js/telegram-client.js
PDF_LEGACY_MODULE_PATH=reference/legacy-js/material-generator.js

# PDF pipeline
FONT_PATH=reference/legacy-js/Caveat-VariableFont_wght.ttf
EMOJI_FONT_PATH=
EMOJI_RENDER_MODE=apple_image
APPLE_EMOJI_BASE_URL=
APPLE_EMOJI_ASSETS_DIR=
PDF_COLOR_SPACE=CMYK
STICKER_SIZE_MM=100
OFFWHITE_HEX=FFFEFA
RASTERIZE_DPI=600

# Generic QR fallback placement (used only as legacy fallback)
QR_A5_RIGHT_MM=10
QR_A5_BOTTOM_MM=10
QR_A5_SIZE_MM=20
QR_A4_RIGHT_MM=10
QR_A4_BOTTOM_MM=10
QR_A4_SIZE_MM=30
