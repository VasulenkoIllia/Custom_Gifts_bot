{
  "name": "custom-gifts-bot",
  "version": "0.1.0",
  "description": "TypeScript rewrite bootstrap for the Custom Gifts production bot",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsc -p tsconfig.test.json && node --test .tmp-test-dist/tests/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "pngjs": "^7.0.0",
    "qrcode": "^1.5.4"
  }
}
