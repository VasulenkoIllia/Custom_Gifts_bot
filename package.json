{
  "name": "custom-gifts-bot",
  "version": "0.1.0",
  "description": "TypeScript rewrite bootstrap for the Custom Gifts production bot",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "migrate": "node dist/scripts/migrate.js",
    "migrate:dev": "tsx src/scripts/migrate.ts",
    "start": "node dist/index.js",
    "test": "node -e \"require('node:fs').rmSync('.tmp-test-dist',{ recursive: true, force: true })\" && tsc -p tsconfig.test.json && node --test .tmp-test-dist/tests/*.test.js",
    "test:orders:business": "npm run build && node dist/scripts/business-logic-order-dry-run.js",
    "test:orders:snapshot": "node dist/scripts/snapshot-order-statuses.js",
    "test:orders:snapshot:dev": "tsx src/scripts/snapshot-order-statuses.ts",
    "test:orders:set-status": "node dist/scripts/set-order-status.js",
    "test:orders:set-status:dev": "tsx src/scripts/set-order-status.ts",
    "test:orders:reset-state": "node dist/scripts/reset-order-processing-state.js",
    "test:orders:reset-state:dev": "tsx src/scripts/reset-order-processing-state.ts",
    "test:order:trigger": "node dist/scripts/manual-order-trigger.js",
    "test:order:trigger:dev": "tsx src/scripts/manual-order-trigger.ts",
    "test:telegram:sync": "node dist/scripts/telegram-sync-updates.js",
    "test:telegram:sync:dev": "tsx src/scripts/telegram-sync-updates.ts",
    "test:orders:restore": "node dist/scripts/restore-order-statuses.js",
    "test:orders:restore:dev": "tsx src/scripts/restore-order-statuses.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.18.0",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "emoji-datasource-apple": "^16.0.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "pngjs": "^7.0.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5"
  }
}
